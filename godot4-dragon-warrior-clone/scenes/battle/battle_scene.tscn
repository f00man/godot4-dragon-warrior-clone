[gd_scene load_steps=2 format=3 uid="uid://battlescene1"]

; External scripts referenced by nodes in this scene.
[ext_resource type="Script" path="res://scenes/battle/battle_scene.gd" id="1"]

; ---------------------------------------------------------------------------
; Scene tree
; ---------------------------------------------------------------------------

; Root node — Node2D with the battle scene script attached.
[node name="BattleScene" type="Node2D"]
script = ExtResource("1")

; Full-screen dark background. Fills the entire viewport via FULL_RECT anchors.
; Dark gray (#141414) evokes the NES Dragon Warrior battle screen.
[node name="Background" type="ColorRect" parent="."]
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 0.0
offset_top = 0.0
offset_right = 0.0
offset_bottom = 0.0
color = Color(0.08, 0.08, 0.08, 1.0)

; Container for the enemy sprite area. Positioned in the upper portion of the
; screen, above the bottom panel. No script — purely structural.
[node name="EnemyArea" type="Control" parent="."]
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 0.0
offset_top = 0.0
offset_right = 0.0
offset_bottom = -120.0

; Placeholder rectangle standing in for the enemy sprite until real art is
; added. Roughly centred in the viewport above the bottom panel.
; NOTE: offset_left/top/right/bottom are approximate for a ~640x400 area
; above the panel — adjust these once the real viewport size is confirmed
; in the Godot editor Project Settings.
[node name="EnemyPlaceholder" type="ColorRect" parent="EnemyArea"]
offset_left = 220.0
offset_top = 100.0
offset_right = 420.0
offset_bottom = 300.0
color = Color(0.3, 0.3, 0.3, 1.0)

; Label showing the enemy's name. Positioned just below the placeholder rect.
; Text and position will be set at runtime by battle_manager.gd once that
; system is implemented.
[node name="EnemyNameLabel" type="Label" parent="EnemyArea"]
offset_left = 220.0
offset_top = 304.0
offset_right = 420.0
offset_bottom = 324.0
text = "Enemy Name"
horizontal_alignment = 1

; Bottom panel — full width, 120 px tall, pinned to the bottom of the viewport.
; anchor_top=1 + anchor_bottom=1 with offset_top=-120 anchors it to the bottom
; edge regardless of viewport height. Will hold party HP/MP bars and action menu.
[node name="BottomPanel" type="ColorRect" parent="."]
anchor_left = 0.0
anchor_right = 1.0
anchor_top = 1.0
anchor_bottom = 1.0
offset_left = 0.0
offset_top = -120.0
offset_right = 0.0
offset_bottom = 0.0
color = Color(0.12, 0.12, 0.12, 1.0)

; Placeholder label inside the bottom panel. Will be replaced with actual
; party member HP/MP bars and the action menu when battle_manager.gd is built.
[node name="PartyPanelLabel" type="Label" parent="BottomPanel"]
offset_left = 8.0
offset_top = 8.0
offset_right = 200.0
offset_bottom = 32.0
text = "Party Panel"
