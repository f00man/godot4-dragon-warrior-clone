[gd_scene load_steps=4 format=3 uid="uid://battlescene1"]

; External scripts and packed scenes referenced by nodes in this scene.
[ext_resource type="Script" path="res://scenes/battle/battle_scene.gd" id="1"]
[ext_resource type="Script" path="res://scripts/systems/battle_manager.gd" id="2"]
[ext_resource type="PackedScene" path="res://scenes/ui/battle_ui.tscn" id="3"]

; ---------------------------------------------------------------------------
; Scene tree
; ---------------------------------------------------------------------------

; Root node — Node2D with the battle scene script attached.
[node name="BattleScene" type="Node2D"]
script = ExtResource("1")

; Full-screen dark background. ColorRect as direct child of Node2D is fine for
; simple full-screen fills — it uses the viewport rect automatically.
[node name="Background" type="ColorRect" parent="."]
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 0.0
offset_top = 0.0
offset_right = 0.0
offset_bottom = 0.0
color = Color(0.08, 0.08, 0.08, 1.0)

; BattleManager — pure logic node, no visual representation.
[node name="BattleManager" type="Node" parent="."]
script = ExtResource("2")

; UILayer — CanvasLayer that hosts all UI Control nodes.
; Controls inside a CanvasLayer always resolve their anchors against the full
; viewport size, regardless of the Node2D hierarchy below. Without this,
; anchor_top=1 on BottomPanel resolves to 1×0=0 and renders off-screen.
[node name="UILayer" type="CanvasLayer" parent="."]
layer = 10

; BattleUI — instanced inside UILayer so anchor-based layout works correctly.
; battle_scene.gd accesses it via $UILayer/BattleUI and calls setup() before
; start_battle() so the battle_started signal is already connected.
[node name="BattleUI" parent="UILayer" instance=ExtResource("3")]
