; ==============================================================================
; CHEST — Node2D using chest.gd, positioned at tile (3,5) = pixel (96, 160).
; item_id="herb" and world_flag="chest_castle_f1_herb" are set as @export vars
; so chest.gd handles all the open/guard/dim logic without any changes here.
; The InteractionZone uses the shared InteractShape (48x48) — same as NPCs.
; ==============================================================================

[node name="Chest" type="Node2D" parent="."]
position = Vector2(96, 160)
script = ExtResource("7_chest")
item_id = "herb"
world_flag = "chest_castle_f1_herb"

; Golden-yellow chest rectangle — visually distinct from floor and walls.
[node name="ChestRect" type="ColorRect" parent="Chest"]
offset_right = 32.0
offset_bottom = 32.0
color = Color(0.7, 0.5, 0.1, 1.0)

; Question mark label floats above the chest to hint that it is interactable.
; offset_top=-20 clears the 32px chest body so it doesn't overlap the graphic.
[node name="ChestLabel" type="Label" parent="Chest"]
offset_left = -8.0
offset_top = -20.0
offset_right = 24.0
offset_bottom = 0.0
text = "?"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 14

; Interaction zone — chest.gd listens to body_entered/exited on this Area2D.
[node name="InteractionZone" type="Area2D" parent="Chest"]

[node name="CollisionShape2D" type="CollisionShape2D" parent="Chest/InteractionZone"]
position = Vector2(16, 16)
shape = SubResource("InteractShape")

; ==============================================================================
; PLAYER — CharacterBody2D at tile (7,3) = pixel (224, 96).
; Layers set in tantegel_floor1.gd._ready(). No Camera2D child — fixed root cam.
; ==============================================================================

[node name="Player" type="CharacterBody2D" parent="."]
position = Vector2(224, 96)
script = ExtResource("2_player")

[node name="CollisionShape2D" type="CollisionShape2D" parent="Player"]
position = Vector2(16, 16)
shape = SubResource("BodyShape")

; Cyan rectangle — temporary player visual until real sprite sheets are added.
[node name="PlaceholderRect" type="ColorRect" parent="Player"]
offset_right = 32.0
offset_bottom = 32.0
color = Color(0.0, 1.0, 1.0, 1.0)

; ==============================================================================
; ENCOUNTER MANAGER — rate 0.0, no battles inside the castle.
; ==============================================================================

[node name="EncounterManager" type="Node" parent="."]
script = ExtResource("3_encountermgr")
base_encounter_rate = 0.0

; ==============================================================================
; DIALOGUE LAYER — CanvasLayer at layer 7, DialogueBox instanced below.
; ==============================================================================

[node name="DialogueLayer" type="CanvasLayer" parent="."]
layer = 7

[node name="DialogueBox" parent="DialogueLayer" instance=ExtResource("6_dialoguebox")]
