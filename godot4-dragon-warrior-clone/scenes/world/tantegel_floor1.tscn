offset_bottom = 32.0
color = Color(0.4, 0.4, 0.8, 1.0)

[node name="NameLabel" type="Label" parent="NPC_GuardNorth"]
offset_left = -16.0
offset_top = -18.0
offset_right = 48.0
offset_bottom = -2.0
text = "Guard"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 8

[node name="InteractionZone" type="Area2D" parent="NPC_GuardNorth"]

[node name="CollisionShape2D" type="CollisionShape2D" parent="NPC_GuardNorth/InteractionZone"]
position = Vector2(16, 16)
shape = SubResource("InteractShape")

; --- Guard (north right, blue tint) ---
; tile (9,2) = pixel (288, 64) — flanking the staircase on the right side.
; Remarks on the dangerous state of the world outside.
[node name="NPC_GuardEntrance" type="CharacterBody2D" parent="."]
position = Vector2(288, 64)
collision_layer = 1
collision_mask = 0
script = ExtResource("4_npcdialogue")
speaker_name = "Guard"
dialogue_pages = ["Welcome to Tantegel Castle. Few dare enter these days, with monsters prowling the roads outside."]

[node name="CollisionShape2D" type="CollisionShape2D" parent="NPC_GuardEntrance"]
