[node name="InteractionZone" type="Area2D" parent="NPC_GuardEntrance"]

[node name="CollisionShape2D" type="CollisionShape2D" parent="NPC_GuardEntrance/InteractionZone"]
position = Vector2(16, 16)
shape = SubResource("InteractShape")

; --- Old Soldier (warm brown tint) ---
; tile (2,4) = pixel (64, 128) — west side of the hall, a veteran voice.
; Two pages: reflects on thirty years of service and the loss of the Ball of Light.
[node name="NPC_OldSoldier" type="CharacterBody2D" parent="."]
position = Vector2(64, 128)
collision_layer = 1
collision_mask = 0
script = ExtResource("4_npcdialogue")
speaker_name = "Old Soldier"
dialogue_pages = ["I have guarded this castle for thirty years. In all my years, I have never seen darkness such as this.", "When I was young, the Ball of Light shone from the throne room, its radiance blessing all of Alefgard. Now only memory remains."]

[node name="CollisionShape2D" type="CollisionShape2D" parent="NPC_OldSoldier"]
position = Vector2(16, 16)
shape = SubResource("BodyShape")

[node name="PlaceholderRect" type="ColorRect" parent="NPC_OldSoldier"]
