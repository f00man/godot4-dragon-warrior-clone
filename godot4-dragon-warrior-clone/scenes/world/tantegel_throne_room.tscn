[node name="PlaceholderRect" type="ColorRect" parent="NPC_GuardLeft"]
offset_right = 32.0
offset_bottom = 32.0
color = Color(0.4, 0.4, 0.8, 1.0)

[node name="NameLabel" type="Label" parent="NPC_GuardLeft"]
offset_left = -16.0
offset_top = -18.0
offset_right = 48.0
offset_bottom = -2.0
text = "Guard"
horizontal_alignment = 1
