; ==============================================================================
; PLAYER — CharacterBody2D at tile (7,3) = pixel (224, 96).
; Collision layers are set in tantegel_floor2.gd._ready() rather than here
; so the intent is explicitly documented in code.
; NOTE: No Camera2D child here — the fixed root Camera2D handles all viewing.
; ==============================================================================

[node name="Player" type="CharacterBody2D" parent="."]
position = Vector2(224, 96)
script = ExtResource("2_player")

[node name="CollisionShape2D" type="CollisionShape2D" parent="Player"]
position = Vector2(16, 16)
shape = SubResource("BodyShape")

; Cyan rectangle — temporary player visual until real sprite sheets are added.
[node name="PlaceholderRect" type="ColorRect" parent="Player"]
offset_right = 32.0
offset_bottom = 32.0
color = Color(0.0, 1.0, 1.0, 1.0)

; ==============================================================================
; ENCOUNTER MANAGER — base_encounter_rate is 0.0 so no battles fire here.
; Kept in the scene tree so tantegel_floor2.gd can reference it consistently
; with how all other world scenes are structured.
; ==============================================================================

[node name="EncounterManager" type="Node" parent="."]
script = ExtResource("3_encountermgr")
base_encounter_rate = 0.0

; ==============================================================================
; DIALOGUE LAYER — CanvasLayer at layer 7 keeps the DialogueBox above all
; world content but below any pause/HUD layers (which use 8+).
; The instanced DialogueBox connects itself to EventManager.dialogue_requested
; in its own _ready() — no additional wiring is needed here.
; ==============================================================================

[node name="DialogueLayer" type="CanvasLayer" parent="."]
layer = 7

[node name="DialogueBox" parent="DialogueLayer" instance=ExtResource("6_dialoguebox")]
