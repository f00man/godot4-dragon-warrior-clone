; ==============================================================================
; tantegel_floor2.tscn
; Part of: godot4-dragon-warrior-clone
; Room: 14 columns x 8 rows at 32px per tile = 448 x 256 pixels world-space.
; Fixed Camera2D at scene root (not parented to Player) shows the full room at
; zoom 2x. Encounters are disabled (base_encounter_rate = 0.0).
; North gap (stairs up to throne room) and south gap (stairs down to floor 1)
; are both centred at x=192–256 (columns 6–7), matching a two-tile opening.
; NPCs: two guards, one sage, one south-door guard.
; ==============================================================================

[gd_scene load_steps=12 format=3 uid="uid://tantegelfloor21"]

; ------------------------------------------------------------------------------
; External resources — scripts and the instanced DialogueBox packed scene.
; IDs are human-readable strings matching the project convention.
; ------------------------------------------------------------------------------

; Root scene script — handles playtime resume and scene-event check.
[ext_resource type="Script" path="res://scenes/world/tantegel_floor2.gd" id="1_floor2"]

; Player entity script — CharacterBody2D with grid-based tile movement.
[ext_resource type="Script" path="res://scripts/entities/player.gd" id="2_player"]

; EncounterManager — rate set to 0.0 so no battles fire inside the castle.
[ext_resource type="Script" path="res://scripts/systems/encounter_manager.gd" id="3_encountermgr"]

; Generic NPC dialogue script — speaker_name and dialogue_pages set per-instance.
[ext_resource type="Script" path="res://scripts/entities/npc_dialogue.gd" id="4_npcdialogue"]

; Staircase auto-trigger — stepping on it immediately transitions to the target scene.
[ext_resource type="Script" path="res://scripts/entities/staircase.gd" id="5_staircase"]

; Reusable DialogueBox packed scene — wires itself to EventManager in its own _ready().
[ext_resource type="PackedScene" uid="uid://dialoguebox1" path="res://scenes/ui/dialogue_box.tscn" id="6_dialoguebox"]

; ------------------------------------------------------------------------------
; Sub-resources — collision shapes shared across multiple nodes.
; Defining them once and referencing by id keeps the file compact and ensures
; that editing a shape updates all users simultaneously in-editor.
; ------------------------------------------------------------------------------

; Partial wall segment — 192px wide (6 tiles), 32px tall (1 tile).
; Used for BOTH the north wall halves AND the south wall halves, since this floor
; has a two-tile gap (192–256 px) in both the north and south walls.
[sub_resource type="RectangleShape2D" id="PartialShape"]
size = Vector2(192, 32)

; Side wall — full room height (256px), one tile (32px) wide.
; Shared by WestWall and EastWall.
[sub_resource type="RectangleShape2D" id="SideShape"]
size = Vector2(32, 256)

; Staircase trigger area — two tiles wide (64px), one tile tall (32px).
; Matches the visible StairRect ColorRect so the trigger visually lines up.
[sub_resource type="RectangleShape2D" id="StairShape"]
size = Vector2(64, 32)

; NPC body collision — slightly smaller than the 32px tile so NPCs feel
; naturally passable at corners, matching Dragon Warrior's grid feel.
[sub_resource type="RectangleShape2D" id="BodyShape"]
size = Vector2(28, 28)

; NPC interaction zone — larger than the body so the player can stand one
; tile away and still trigger Accept-to-talk. 48x48 = 1.5 tiles.
[sub_resource type="RectangleShape2D" id="InteractShape"]
size = Vector2(48, 48)

; ==============================================================================
; NODE TREE
; ==============================================================================

; Root Node2D — no position needed; all children are laid out in world-space.
[node name="TantegelFloor2" type="Node2D"]
script = ExtResource("1_floor2")

; ------------------------------------------------------------------------------
; Fixed Camera — NOT parented to the Player.
; Centred at room midpoint (224, 128) with zoom=2 so all 448x256 world pixels
; map to 896x512 screen pixels, keeping NES proportions readable on modern screens.
; ------------------------------------------------------------------------------
[node name="Camera2D" type="Camera2D" parent="."]
position = Vector2(224, 128)
zoom = Vector2(2, 2)

; Warm tan stone floor — fills the entire room (448 x 256 px).
; Placeholder until real tile art is added; drawn first so walls render on top.
[node name="FloorBackground" type="ColorRect" parent="."]
offset_right = 448.0
offset_bottom = 256.0
color = Color(0.65, 0.55, 0.4, 1.0)

; ==============================================================================
; WALLS — StaticBody2D nodes with RectangleShape2D collision.
; collision_layer=1 matches the tile physics layer so Player's move_and_collide
; stops here. collision_mask=1 is standard for static scenery.
; This floor has a two-tile gap (x=192–256) in BOTH north and south walls
; to accommodate staircases at both ends.
; ==============================================================================

; North wall left — columns 0–6 (0–192 px), row 0 (y=0..32).
; Shape centre: (96, 16) — midpoint of the left half.
[node name="NorthWallLeft" type="StaticBody2D" parent="."]
collision_layer = 1
collision_mask = 1

[node name="CollisionShape2D" type="CollisionShape2D" parent="NorthWallLeft"]
position = Vector2(96, 16)
shape = SubResource("PartialShape")

[node name="WallRect" type="ColorRect" parent="NorthWallLeft"]
offset_right = 192.0
offset_bottom = 32.0
color = Color(0.2, 0.2, 0.25, 1.0)

; North wall right — columns 8–14 (256–448 px), row 0.
; Shape centre: (352, 16) — midpoint of the right half.
[node name="NorthWallRight" type="StaticBody2D" parent="."]
collision_layer = 1
collision_mask = 1

[node name="CollisionShape2D" type="CollisionShape2D" parent="NorthWallRight"]
position = Vector2(352, 16)
shape = SubResource("PartialShape")

[node name="WallRect" type="ColorRect" parent="NorthWallRight"]
offset_left = 256.0
offset_right = 448.0
offset_bottom = 32.0
color = Color(0.2, 0.2, 0.25, 1.0)

; South wall left — columns 0–6 (0–192 px), row 7 (y=224..256).
; Leaves the centre gap open for the downward staircase.
[node name="SouthWallLeft" type="StaticBody2D" parent="."]
collision_layer = 1
collision_mask = 1

[node name="CollisionShape2D" type="CollisionShape2D" parent="SouthWallLeft"]
position = Vector2(96, 240)
shape = SubResource("PartialShape")

[node name="WallRect" type="ColorRect" parent="SouthWallLeft"]
offset_top = 224.0
offset_right = 192.0
offset_bottom = 256.0
color = Color(0.2, 0.2, 0.25, 1.0)

; South wall right — columns 8–14 (256–448 px), row 7.
[node name="SouthWallRight" type="StaticBody2D" parent="."]
collision_layer = 1
collision_mask = 1

[node name="CollisionShape2D" type="CollisionShape2D" parent="SouthWallRight"]
position = Vector2(352, 240)
shape = SubResource("PartialShape")

[node name="WallRect" type="ColorRect" parent="SouthWallRight"]
offset_left = 256.0
offset_top = 224.0
offset_right = 448.0
offset_bottom = 256.0
color = Color(0.2, 0.2, 0.25, 1.0)

; West wall — column 0 (0–32 px), full room height (0–256 px).
[node name="WestWall" type="StaticBody2D" parent="."]
collision_layer = 1
collision_mask = 1

[node name="CollisionShape2D" type="CollisionShape2D" parent="WestWall"]
position = Vector2(16, 128)
shape = SubResource("SideShape")

[node name="WallRect" type="ColorRect" parent="WestWall"]
offset_right = 32.0
offset_bottom = 256.0
color = Color(0.2, 0.2, 0.25, 1.0)

; East wall — column 13 (416–448 px), full room height.
[node name="EastWall" type="StaticBody2D" parent="."]
collision_layer = 1
collision_mask = 1

[node name="CollisionShape2D" type="CollisionShape2D" parent="EastWall"]
position = Vector2(432, 128)
shape = SubResource("SideShape")

[node name="WallRect" type="ColorRect" parent="EastWall"]
offset_left = 416.0
offset_right = 448.0
offset_bottom = 256.0
color = Color(0.2, 0.2, 0.25, 1.0)

; ==============================================================================
; STAIRCASES — Area2D nodes using staircase.gd auto-trigger.
; Stepping on the collision shape immediately transitions to the target scene.
; spawn_tile sets GameState.player_position before the scene swap so the player
; appears at the correct landing tile in the destination.
; ==============================================================================

; Stairs up — north gap (x=192–256, y=0–32) — leads to tantegel_throne_room.
; spawn_tile Vector2(6,6) places the player on the downward stairs in that room,
; just north of the staircase landing (tile row 6).
[node name="StairsUp" type="Area2D" parent="."]
script = ExtResource("5_staircase")
target_scene = "res://scenes/world/tantegel_throne_room.tscn"
spawn_tile = Vector2(6, 6)

[node name="CollisionShape2D" type="CollisionShape2D" parent="StairsUp"]
position = Vector2(224, 16)
shape = SubResource("StairShape")

; Visual placeholder — dark blue-grey matching the throne room stair colour.
[node name="StairRect" type="ColorRect" parent="StairsUp"]
offset_left = 192.0
offset_top = 0.0
offset_right = 256.0
offset_bottom = 32.0
color = Color(0.35, 0.35, 0.45, 1.0)

; Upward arrow label — floats just below the staircase tile so the player
; can identify the direction at a glance without covering the opening.
[node name="StairLabel" type="Label" parent="StairsUp"]
offset_left = 192.0
offset_top = 33.0
offset_right = 256.0
offset_bottom = 49.0
text = "▲"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 14

; Stairs down — south gap (x=192–256, y=224–256) — leads to tantegel_floor1.
; spawn_tile Vector2(7,1) places the player near the top of Floor 1, just below
; the upward staircase opening on that floor.
[node name="StairsDown" type="Area2D" parent="."]
script = ExtResource("5_staircase")
target_scene = "res://scenes/world/tantegel_floor1.tscn"
spawn_tile = Vector2(7, 1)

[node name="CollisionShape2D" type="CollisionShape2D" parent="StairsDown"]
position = Vector2(224, 240)
shape = SubResource("StairShape")

[node name="StairRect" type="ColorRect" parent="StairsDown"]
offset_left = 192.0
offset_top = 224.0
offset_right = 256.0
offset_bottom = 256.0
color = Color(0.35, 0.35, 0.45, 1.0)

; Downward arrow label — floats just above the staircase tile.
[node name="StairLabel" type="Label" parent="StairsDown"]
offset_left = 192.0
offset_top = 206.0
offset_right = 256.0
offset_bottom = 222.0
text = "▼"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 14

; ==============================================================================
; NPCs — CharacterBody2D nodes using npc_dialogue.gd.
; collision_layer=1 so the player bumps against them (impassable).
; collision_mask=0 so NPCs do not push each other or interact with wall shapes.
; Each NPC follows the standard structure:
;   CollisionShape2D at local (16,16) — body collision (28x28 BodyShape)
;   PlaceholderRect 32x32             — faction colour fill, no offset
;   NameLabel                         — 8px font, centred, floats above sprite
;   InteractionZone Area2D            — 48x48 detect area, triggers _speak() on Accept
; ==============================================================================

; --- Guard (north area, blue tint) ---
; tile (6,2) = pixel (192, 64) — standing near the upward staircase, directing
; players who have just arrived from Floor 1 upward toward the throne room.
[node name="NPC_GuardNorth" type="CharacterBody2D" parent="."]
position = Vector2(192, 64)
collision_layer = 1
collision_mask = 0
script = ExtResource("4_npcdialogue")
speaker_name = "Guard"
dialogue_pages = ["Those stairs lead upward to the throne room, where King Lorik holds court."]

[node name="CollisionShape2D" type="CollisionShape2D" parent="NPC_GuardNorth"]
position = Vector2(16, 16)
shape = SubResource("BodyShape")

[node name="PlaceholderRect" type="ColorRect" parent="NPC_GuardNorth"]
offset_right = 32.0
offset_bottom = 32.0
color = Color(0.4, 0.4, 0.8, 1.0)

[node name="NameLabel" type="Label" parent="NPC_GuardNorth"]
offset_left = -16.0
offset_top = -18.0
offset_right = 48.0
offset_bottom = -2.0
text = "Guard"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 8

[node name="InteractionZone" type="Area2D" parent="NPC_GuardNorth"]

[node name="CollisionShape2D" type="CollisionShape2D" parent="NPC_GuardNorth/InteractionZone"]
position = Vector2(16, 16)
shape = SubResource("InteractShape")

; --- Guard (east patrol, blue tint) ---
; tile (11,3) = pixel (352, 96) — patrolling the east side of the hall.
; Gives the player information about the monster threat to the south.
[node name="NPC_GuardPatrol" type="CharacterBody2D" parent="."]
position = Vector2(352, 96)
collision_layer = 1
collision_mask = 0
script = ExtResource("4_npcdialogue")
speaker_name = "Guard"
dialogue_pages = ["The Dragonlord's minions have been seen moving southward from his domain. Be on guard when thou leavest the castle."]

[node name="CollisionShape2D" type="CollisionShape2D" parent="NPC_GuardPatrol"]
position = Vector2(16, 16)
shape = SubResource("BodyShape")

[node name="PlaceholderRect" type="ColorRect" parent="NPC_GuardPatrol"]
offset_right = 32.0
offset_bottom = 32.0
color = Color(0.4, 0.4, 0.8, 1.0)

[node name="NameLabel" type="Label" parent="NPC_GuardPatrol"]
offset_left = -16.0
offset_top = -18.0
offset_right = 48.0
offset_bottom = -2.0
text = "Guard"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 8

[node name="InteractionZone" type="Area2D" parent="NPC_GuardPatrol"]

[node name="CollisionShape2D" type="CollisionShape2D" parent="NPC_GuardPatrol/InteractionZone"]
position = Vector2(16, 16)
shape = SubResource("InteractShape")

; --- Sage (light blue-white tint) ---
; tile (4,4) = pixel (128, 128) — west-centre of the hall.
; Provides two-page lore about Erdrick's legacy and his hidden artifacts.
[node name="NPC_Sage" type="CharacterBody2D" parent="."]
position = Vector2(128, 128)
collision_layer = 1
collision_mask = 0
script = ExtResource("4_npcdialogue")
speaker_name = "Sage"
dialogue_pages = ["The hero Erdrick once walked these very halls. His legacy lives on in thee.", "Erdrick's Armor, Sword, and Token are hidden somewhere in Alefgard. Find them and thy power shall be greatly enhanced."]

