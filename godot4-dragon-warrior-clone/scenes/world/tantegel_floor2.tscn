script = ExtResource("4_npcdialogue")
speaker_name = "Guard"
dialogue_pages = ["Those stairs descend to the castle entrance. Brecconary lies just south of the castle gates."]

[node name="CollisionShape2D" type="CollisionShape2D" parent="NPC_GuardSouth"]
