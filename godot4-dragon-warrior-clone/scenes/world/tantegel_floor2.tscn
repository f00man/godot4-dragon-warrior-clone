; --- Guard (south door, blue tint) ---
; tile (7,6) = pixel (224, 192) — standing near the downward staircase opening.
; Guides the player toward Brecconary once they descend to Floor 1 and exit.
[node name="NPC_GuardSouth" type="CharacterBody2D" parent="."]
position = Vector2(224, 192)
collision_layer = 1
