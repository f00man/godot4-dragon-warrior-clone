[gd_scene format=3 uid="uid://dialoguebox1"]

[ext_resource type="Script" path="res://scenes/ui/dialogue_box.gd" id="1_dlgbox"]

; DialogueBox — root Control fills the full viewport. The script manages
; visibility (starts hidden). Anchors preset 15 = full-rect.
[node name="DialogueBox" type="Control"]
script = ExtResource("1_dlgbox")
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
offset_right = 0.0
offset_bottom = 0.0
grow_horizontal = 2
grow_vertical = 2

; Panel anchored to the bottom of the viewport, full width, 220px tall.
; anchor_top=1 + offset_top=-220 keeps it pinned regardless of resolution.
; 220px at 1080p gives a comfortable JRPG dialogue bar — roughly 20% of height.
[node name="Panel" type="Panel" parent="."]
layout_mode = 1
anchor_left = 0.0
anchor_top = 1.0
anchor_right = 1.0
anchor_bottom = 1.0
offset_top = -220.0
offset_bottom = 0.0
grow_horizontal = 2
grow_vertical = 0

; VBox fills the Panel with a 16px margin on all sides.
[node name="VBox" type="VBoxContainer" parent="Panel"]
layout_mode = 1
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 16.0
offset_top = 12.0
offset_right = -16.0
offset_bottom = -12.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 8

; SpeakerLabel — shown when a speaker name is provided; hidden otherwise.
[node name="SpeakerLabel" type="Label" parent="Panel/VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 20

; TextLabel — main dialogue text, word-wraps automatically.
[node name="TextLabel" type="Label" parent="Panel/VBox"]
layout_mode = 2
size_flags_vertical = 3
autowrap_mode = 3
theme_override_font_sizes/font_size = 24

; ChoicesContainer — holds dynamically created choice buttons.
; Hidden until the final page of a dialogue with branching choices.
[node name="ChoicesContainer" type="VBoxContainer" parent="Panel/VBox"]
layout_mode = 2
visible = false
theme_override_constants/separation = 6

; ContinueIndicator — classic "▼" prompt anchored to the bottom-right of Panel.
[node name="ContinueIndicator" type="Label" parent="Panel"]
layout_mode = 1
anchor_left = 1.0
anchor_top = 1.0
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = -48.0
offset_top = -40.0
offset_right = -12.0
offset_bottom = -12.0
grow_horizontal = 0
grow_vertical = 0
visible = false
text = "▼"
horizontal_alignment = 1
vertical_alignment = 1
theme_override_font_sizes/font_size = 20

; TypewriterTimer — drives character-reveal animation (0.04s per character).
[node name="TypewriterTimer" type="Timer" parent="."]
wait_time = 0.04
one_shot = true
autostart = false
